# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Hero: Calendly-Link (öffentlich, wird im Client eingebunden)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/dein-team/30min

# Launch-Liste / CRM (nur Server – nie NEXT_PUBLIC_)
# klaviyo = Standard (Liste + Marketing-Consent)
# pipedrive = Kontakt als Person
# none = nur Log, kein externes CRM (z. B. lokal testen)
CRM_PROVIDER=klaviyo

# Klaviyo: Private API Key + Listen-ID (Klaviyo → Audience → List ID)
KLAVIYO_PRIVATE_API_KEY=
KLAVIYO_LIST_ID=
# Optional, falls Klaviyo eine neuere Revision verlangt:
# KLAVIYO_API_REVISION=2024-10-15

# Pipedrive (nur wenn CRM_PROVIDER=pipedrive)
# Subdomain aus https://SUBDOMAIN.pipedrive.com
# PIPEDRIVE_API_TOKEN=
# PIPEDRIVE_COMPANY_DOMAIN=
