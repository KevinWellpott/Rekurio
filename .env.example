# =============================================================================
# Rekurio – Umgebungsvariablen (Kopie nach .env.local und Werte eintragen)
# =============================================================================
# .env.local ist gitignored und gehört nicht ins Repo.
# Vercel: dieselben Keys im Projekt unter Settings → Environment Variables setzen.
# =============================================================================

# --- App & URLs (öffentlich, NEXT_PUBLIC_*) ---------------------------------
# Öffentliche Basis-URL (Meta, Links, siteConfig). Lokal: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Kanonische Domain für Sitemap + robots.txt (hat Vorrang vor APP_URL).
# Production z. B. https://rekurio.de oder https://www.rekurio.com
# NEXT_PUBLIC_BASE_URL=https://rekurio.de

# Calendly (Demo/CTA-Links – wird im Client eingebunden)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/dein-team/30min

# --- PostHog (Analytics, EU) -------------------------------------------------
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# EU: https://eu.i.posthog.com | US: https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Launch-Liste / CRM (nur Server – nie NEXT_PUBLIC_) ----------------------
# klaviyo | pipedrive | none (nur Log, kein externes CRM)
CRM_PROVIDER=klaviyo

KLAVIYO_PRIVATE_API_KEY=
KLAVIYO_LIST_ID=
# Optional, Standard im Code: 2024-10-15
# KLAVIYO_API_REVISION=2024-10-15

# Nur wenn CRM_PROVIDER=pipedrive (Subdomain ohne .pipedrive.com)
# PIPEDRIVE_API_TOKEN=
# PIPEDRIVE_COMPANY_DOMAIN=

# --- Magic UI Pro (nur für CLI: npx shadcn add @magicui-pro/…) --------------
# Wird von components.json referenziert, nicht zur Laufzeit von Next.js gelesen.
# MAGICUI_PRO_REGISTRY_TOKEN=
